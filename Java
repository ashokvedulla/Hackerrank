public class Solution {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);

        // Read integer
        int i = scanner.nextInt();

        // Read double
        double d = scanner.nextDouble();

        // Consume the leftover newline
        scanner.nextLine();

        // Read String
